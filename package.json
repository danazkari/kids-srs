{
  "name": "kids-srs",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Spaced repetition study app for young children (ages 5-8). Fully offline PWA.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy": "bun run build && bun --env-file=.env run surge:only",
    "deploy:preview": "bun run build && bun --env-file=.env run surge:preview",
    "surge:only": "surge dist $SURGE_DOMAIN",
    "surge:preview": "surge dist ${SURGE_DOMAIN:-preview.surge.sh} --preview"
  },
  "dependencies": {
    "chart.js": "^4.4.4",
    "idb": "^8.0.0",
    "preact": "^10.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^10",
    "@preact/preset-vite": "^2.9.1",
    "eslint": "^10",
    "globals": "^17",
    "happy-dom": "^20.9.0",
    "prettier": "^3",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^4.1.8",
    "workbox-window": "^7.1.0"
  }
}
